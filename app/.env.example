# ─────────────────────────────────────────────
# Supabase — public values (safe to share)
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://iwausfzgitoehqecrvxc.supabase.co
# Anon/public key — designed for client-side use, protected by Row-Level Security
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────
# Supabase — server-side only
# ─────────────────────────────────────────────
SUPABASE_URL=https://iwausfzgitoehqecrvxc.supabase.co
# SERVICE KEY — full database access. NEVER expose to the frontend.
# Set this in Vercel dashboard → Settings → Environment Variables
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
VITE_API_URL=/api

# ─────────────────────────────────────────────
# Flutterwave — public key (safe to share, client-side only)
# ─────────────────────────────────────────────
VITE_FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key_here

# Flutterwave — SECRET, server-side only
# Set this in Vercel dashboard → Settings → Environment Variables
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key_here
FLUTTERWAVE_WEBHOOK_SECRET_HASH=your_flutterwave_webhook_secret_hash_here

# ─────────────────────────────────────────────
# DeCart AI — SECRET, server/Electron main-process only
# Set this in Vercel dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────
DECART_API_KEY=your_decart_api_key_here

