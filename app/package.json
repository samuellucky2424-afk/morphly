{
  "name": "morphly-desktop",
  "private": true,
  "version": "1.2.18",
  "description": "Morphly Desktop Electron package with bundled virtual camera install flow.",
  "author": "Morphly",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win",
    "electron:build:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.morphly.app",
    "productName": "Morphly Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": "."
      }
    ],
    "afterPack": "build/afterPack.cjs",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "Morphly Setup ${version}.${ext}",
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "Morphly ${version}.${ext}"
    }
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "electron": "41.1.0",
    "electron-builder": "26.8.1"
  }
}